body {
  font-family: Arial;
  background: #f5f5f5;
  padding: 20px;
}

.wrap {
  max-width: 900px;
  margin: auto;
}

.card {
  background: white;
  padding: 20px;
  margin-bottom: 20px;
  border-radius: 10px;
}

input, select, button {
  width: 100%;
  margin-top: 10px;
  padding: 10px;
}

button {
  background: black;
  color: white;
  border: none;
}

.item {
  border-bottom: 1px solid #ddd;
  padding: 10px 0;
}
